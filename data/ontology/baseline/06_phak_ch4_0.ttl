:Cl_AtmosphericComposition rdfs:subClassOf [ a owl:Restriction ; owl:onProperty :hasQuantity ; owl:someValuesFrom :Cl_FractionQuantity ] .
:Cl_AtmosphericStratification rdfs:subClassOf [ a owl:Restriction ; owl:onProperty :appliesTo ; owl:someValuesFrom :Cl_Gas ] .
