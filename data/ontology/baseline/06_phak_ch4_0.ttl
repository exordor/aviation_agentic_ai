:Cl_Atmosphere rdfs:subClassOf [ a owl:Restriction ; owl:onProperty :surrounds ; owl:someValuesFrom :Cl_Earth ] .
:Cl_Atmosphere rdfs:subClassOf [ a owl:Restriction ; owl:onProperty :restsUpon ; owl:someValuesFrom :Cl_EarthSurface ] .
:Cl_Atmosphere rdfs:subClassOf [ a owl:Restriction ; owl:onProperty :composedOf ; owl:someValuesFrom :Cl_Gas ] .
:Cl_Air rdfs:subClassOf [ a owl:Restriction ; owl:onProperty :composedOf ; owl:someValuesFrom :Cl_Gas ] .
