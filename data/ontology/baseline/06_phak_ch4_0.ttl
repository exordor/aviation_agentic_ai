:hasMember rdfs:subPropertyOf :hasComponent .
:hasComponent rdfs:subPropertyOf :composedOf .
:surrounds rdfs:domain :Cl_Atmosphere ; rdfs:range :Cl_Earth .
:restsUpon rdfs:domain :Cl_Atmosphere ; rdfs:range :Cl_EarthSurface .
:composedOf rdfs:domain owl:Thing ; rdfs:range owl:Thing .
:hasComponent rdfs:domain owl:Thing ; rdfs:range owl:Thing .
:hasQuantity rdfs:domain owl:Thing ; rdfs:range :Cl_QuantityAssertion .
:appliesTo rdfs:domain :Cl_QuantityAssertion ; rdfs:range owl:Thing .
:belowAltitude rdfs:domain :Cl_AtmosphericStratification ; rdfs:range :Cl_AltitudeRegion .
:aboveAltitude rdfs:domain :Cl_AtmosphericStratification ; rdfs:range :Cl_AltitudeRegion .
:hasThreshold rdfs:domain :Cl_Constraint ; rdfs:range :Cl_QuantityAssertion .
:hasOutcome rdfs:domain :Cl_Constraint ; rdfs:range owl:Thing .
:hasNumericValue rdfs:domain :Cl_QuantityAssertion ; rdfs:range xsd:decimal .
:hasFractionValue rdfs:domain :Cl_FractionQuantity ; rdfs:range xsd:decimal .
:hasUnit rdfs:domain :Cl_QuantityAssertion ; rdfs:range owl:Thing .
