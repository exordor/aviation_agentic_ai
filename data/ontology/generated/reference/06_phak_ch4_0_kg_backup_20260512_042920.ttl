    :hasTextValue "A wing moving through air generates the force called lift" .
:liftGreaterThanGravityCondition a :Cl_ConditionAssertion ;
    :sourcePage :Cl_Page4_4 ;
    :mentions :Cl_Lift , :Cl_Gravity , :Cl_Aircraft ;
    :hasTextValue "Lift from the wing that is greater than the force of gravity, directed opposite to the direction of gravity, enables an aircraft to fly" .
:liftOpposesGravityFact a owl:NamedIndividual ;
    :sourcePage :Cl_Page4_4 ;
    :mentions :Cl_Lift , :Cl_Gravity ;
    :hasTextValue "directed opposite to the direction of gravity" .
:liftTheoryAssertion a :Cl_FlightPrincipleAssertion ;
    :sourcePage :Cl_Page4_4 ;
    :mentions :Cl_Lift , :Cl_NewtonsFirstLaw , :Cl_NewtonsSecondLaw , :Cl_Pressure ;
    :hasTextValue "Generating this force called lift is based on some important principles, Newton's basic laws of motion, and Bernoulli's principle of differential pressure" .
:liftNotFullyExplainedByNewtonFact a owl:NamedIndividual ;
    :sourcePage :Cl_Page4_4 ;
    :mentions :Cl_Lift , :Cl_NewtonsFirstLaw , :Cl_NewtonsSecondLaw , :Cl_Airfoil ;
    :hasTextValue "These laws, although seemingly applicable to all aspects of lift, do not explain how lift is formulated" .
:symmetricalAirfoilLiftFact a owl:NamedIndividual ;
    :sourcePage :Cl_Page4_4 ;
    :mentions :Cl_Airfoil , :Cl_Lift ;
    :hasTextValue "many airfoils that are symmetrical, yet produce significant lift" .
:newtonIsaacFact a owl:NamedIndividual ;
    :sourcePage :Cl_Page4_4 ;
    :hasTextValue "Sir Isaac Newton" .
:newtonsFirstLawStatement a :Cl_NewtonsFirstLaw ;
    :sourcePage :Cl_Page4_4 ;
    :mentions :Cl_Object , :Cl_Force ;
    :hasTextValue "Every object persists in its state of rest or uniform motion in a straight line unless it is compelled to change that state by forces impressed on it." .
:aircraftAtRestOnRampFact a owl:NamedIndividual ;
    :sourcePage :Cl_Page4_4 ;
    :mentions :Cl_Aircraft , :Cl_Inertia , :Cl_Force ;
    :hasTextValue "An aircraft at rest on the ramp remains at rest unless a force strong enough to overcome its inertia is applied" .
:aircraftInMotionFact a owl:NamedIndividual ;
    :sourcePage :Cl_Page4_4 ;
    :mentions :Cl_Inertia , :Cl_Aircraft , :Cl_Motion , :Cl_Force ;
    :hasTextValue "Once it is moving, its inertia keeps it moving, subject to the various other forces acting on it" .
:forcesMayAlterMotionFact a owl:NamedIndividual ;
    :sourcePage :Cl_Page4_4 ;
    :mentions :Cl_Force , :Cl_Aircraft , :Cl_Motion ;
    :hasTextValue "These forces may add to its motion, slow it down, or change its direction" .
:newtonsSecondLawStatement a :Cl_NewtonsSecondLaw ;
    :sourcePage :Cl_Page4_4 ;
    :mentions :Cl_Force , :Cl_Momentum , :Cl_Time , :Cl_Mass , :Cl_Acceleration ;
    :hasTextValue "Force is equal to the change in momentum per change in time. For a constant mass, force equals mass times acceleration." .
:forceEqualsMassTimesAccelerationFact a owl:NamedIndividual ;
    :sourcePage :Cl_Page4_4 ;
    :mentions :Cl_Force , :Cl_Mass , :Cl_Acceleration ;
    :hasTextValue "For a constant mass, force equals mass times acceleration" .
:aircraftFlyCondition a :Cl_ConditionAssertion ;
    :sourcePage :Cl_Page4_4 ;
    :mentions :Cl_Aircraft , :Cl_Lift , :Cl_Gravity , :Cl_Wing ;
    :hasTextValue "when lift from the wing is greater than the force of gravity" .
