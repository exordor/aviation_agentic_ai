    :sourcePage :chapter4SourcePage ;
    :hasTextValue "the air pushes the propeller (and thus the airplane) in the opposite direction—forward" .

:propellerPushesAirFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasParticipant :Cl_Propeller , :Cl_Air ;
    :hasTextValue "the propeller moves and pushes back the air" .

:jetReactionAssertion a :Cl_JetReaction ;
