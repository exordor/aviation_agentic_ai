    :sourcePage :chapter4SourcePage ;
    :variesWith :Cl_Altitude , :Cl_AtmosphericPressure , :Cl_Temperature , :Cl_Humidity ;
    :hasTextValue "high elevations, low atmospheric pressures, high temperatures, high humidity, or some combination" .
:denseAirSituation a :Cl_DenseAir ;
    :sourcePage :chapter4SourcePage ;
    :variesWith :Cl_Altitude , :Cl_AtmosphericPressure , :Cl_Temperature , :Cl_Humidity ;
    :hasTextValue "lower elevations, high atmospheric pressure, low temperatures, and low humidity" .
:airCompressedAssertion a :Cl_FlightPrincipleAssertion ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_Air , :Cl_Container , :Cl_Pressure ;
    :asserts :airCompressedFact .
:airCompressedFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "When air is compressed, a greater amount of air can occupy a given volume." .
:airExpandedAssertion a :Cl_FlightPrincipleAssertion ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_Air , :Cl_Container , :Cl_Pressure ;
    :asserts :airExpandedFact .
:airExpandedFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "when pressure on a given volume of air is decreased, the air expands and occupies a greater space" .
:airMassSmallerAtLowerPressureAssertion a :Cl_FlightPrincipleAssertion ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_Air , :Cl_Mass , :Cl_Pressure ;
    :asserts :airMassSmallerAtLowerPressureFact .
:airMassSmallerAtLowerPressureFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "At a lower pressure, the original column of air contains a smaller mass of air." .
:densityPressureProportionalityAssertion a :Cl_PressureAssertion ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_Density , :Cl_Pressure , :Cl_Temperature ;
    :asserts :densityDirectlyProportionalToPressureFact .
