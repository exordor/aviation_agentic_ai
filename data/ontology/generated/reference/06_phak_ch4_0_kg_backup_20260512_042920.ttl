:bernoulliPrincipleAssertion a :Cl_BernoulliPrinciple ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_Fluid , :Cl_Air , :Cl_Pressure , :Cl_Velocity ;
    :hasTextValue "as the velocity of a moving fluid increases, the pressure within the fluid decreases" ;
    :governs :venturiTubeAssertion ;
    :causes :pressureDecreaseFact .

:pressureDecreaseFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_Pressure , :Cl_Velocity , :Cl_Fluid ;
    :hasTextValue "the pressure within the fluid decreases" .

:venturiTubeAssertion a :Cl_VenturiTube ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_Air , :Cl_Fluid , :Cl_Pressure ;
    :hasPart :venturiInletSection , :venturiThroatSection , :venturiOutletSection ;
    :hasTextValue "A practical application of Bernoulli's Principle is the venturi tube" .

:venturiInletSection a :Cl_Container ;
    :sourcePage :chapter4SourcePage ;
    :partOf :venturiTubeAssertion ;
    :hasTextValue "air inlet" .

:venturiThroatSection a :Cl_Throat , :Cl_ConstrictedPoint ;
    :sourcePage :chapter4SourcePage ;
    :partOf :venturiTubeAssertion ;
    :hasTextValue "throat (constricted point)" .

:venturiOutletSection a :Cl_OutletSection ;
    :sourcePage :chapter4SourcePage ;
    :partOf :venturiTubeAssertion ;
    :hasTextValue "outlet section that increases in diameter toward the rear" .

:venturiInletDiameterAssertion a :Cl_QuantityAssertion ;
    :sourcePage :chapter4SourcePage ;
    :appliesTo :venturiInletSection ;
    :hasTextValue "same as that of the inlet" .

:venturiOutletDiameterAssertion a :Cl_QuantityAssertion ;
    :sourcePage :chapter4SourcePage ;
    :appliesTo :venturiOutletSection ;
    :hasTextValue "the diameter of the outlet is the same as that of the inlet" .

:venturiMassEqualityAssertion a :Cl_QuantityAssertion ;
    :sourcePage :chapter4SourcePage ;
    :appliesTo :venturiTubeAssertion ;
    :hasTextValue "The mass of air entering the tube must exactly equal the mass exiting the tube" .

:venturiConstrictionSpeedAssertion a :Cl_VenturiFlowAssertion ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_AirFlow , :Cl_Throat ;
    :hasCondition :venturiThroatSection ;
    :hasOutcome :venturiSpeedIncreaseFact .

:venturiSpeedIncreaseFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "At the constriction, the speed must increase to allow the same amount of air to pass in the same amount of time" .

:venturiPressureDecreaseAssertion a :Cl_BernoulliCausalAssertion ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_Pressure , :Cl_AirFlow ;
    :hasCondition :venturiSpeedIncreaseFact ;
    :hasOutcome :venturiPressureDecreaseFact .

:venturiPressureDecreaseFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "When the air speeds up, the pressure also decreases" .

:venturiPastConstrictionAssertion a :Cl_VenturiFlowAssertion ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_AirFlow , :Cl_Pressure ;
    :hasCondition :venturiThroatSection ;
    :hasOutcome :venturiSlowFlowFact .

:venturiSlowFlowFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "Past the constriction, the airflow slows and the pressure increases" .

