    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_Altimeter , :Cl_Pressure , :Cl_Atmosphere ;
    :asserts :altimeterSensitiveBarometerFact .
:altimeterSensitiveBarometerFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "An altimeter is essentially a sensitive barometer calibrated to indicate altitude in the standard atmosphere." .
:pressureAltitudeDefinitionAssertion a :Cl_FlightPrincipleAssertion ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_PressureAltitude , :Cl_StandardDatumPlane , :Cl_Altitude ;
    :asserts :pressureAltitudeDefinitionFact .
