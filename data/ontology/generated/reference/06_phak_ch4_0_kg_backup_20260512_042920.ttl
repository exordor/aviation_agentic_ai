    :sourcePage :chapter4SourcePage ;
    :measuredFrom :Cl_SeaLevel ;
    :dependsOn :pressureAltitudeDefinitionFact ;
    :hasTextValue "the vertical distance above sea level in the standard atmosphere at which a given density is to be found" .
:densityAltitudePerformanceAssertion a :Cl_FlightPrincipleAssertion ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_DensityAltitude , :Cl_FlightPerformanceCharacteristic , :Cl_Aircraft ;
    :asserts :densityAltitudePerformanceFact .
