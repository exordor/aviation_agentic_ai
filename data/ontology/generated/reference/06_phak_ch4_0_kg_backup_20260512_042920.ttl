    :sourcePage :chapter4SourcePage ;
    :hasCondition :thinAirSituation ;
    :hasTextValue "high density altitude refers to thin air" .
:lowDensityAltitudeSituation a :Cl_LowDensityAltitude ;
    :sourcePage :chapter4SourcePage ;
    :hasCondition :denseAirSituation ;
    :hasTextValue "low density altitude refers to dense air" .
