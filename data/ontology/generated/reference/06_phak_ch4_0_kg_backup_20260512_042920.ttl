    :sourcePage :chapter4SourcePage ;
    :directlyProportionalTo :Cl_Pressure ;
    :hasTextValue "density is directly proportional to pressure" .
:densityTemperatureProportionalityAssertion a :Cl_TemperatureAssertion ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_Density , :Cl_Temperature ;
    :asserts :densityInverselyProportionalToTemperatureFact .
:densityInverselyProportionalToTemperatureFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :inverselyProportionalTo :Cl_Temperature ;
    :hasTextValue "the density of air varies inversely with temperature" .
:pressureDoublesDensityDoublesFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "If the pressure is doubled, the density is doubled" .
:pressureLoweredDensityLoweredFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "if the pressure is lowered, the density is lowered" .
:constantTemperatureConstraintFact a :Cl_Constraint ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "This statement is true only at a constant temperature" .
:constantPressureConstraintFact a :Cl_Constraint ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "This statement is true only at a constant pressure" .
:temperatureDecreaseWithAltitudeFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "both temperature and pressure decrease with altitude" .
:pressureDropDominatesDensityFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "a fairly rapid drop in pressure as altitude increases usually has a dominating effect" .
:pilotDensityExpectationFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "pilots can expect the density to decrease with altitude" .
:densityAltitudePerformanceEqualityFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "Regardless of the actual altitude of the aircraft, it will perform as though it were operating at an altitude equal to the existing density altitude" .
:pressureAndTemperatureFactorsFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "The computation of density altitude involves consideration of pressure and temperature" .
:altimeterLimitationFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "these levels cannot be determined directly from the altimeter" .
:densityAltitudeSequenceFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "Density altitude is determined by first finding pressure altitude, and then correcting this altitude for nonstandard temperature variations" .
:airDensityVariesWithAltitudeFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "Air density is affected by changes in altitude, temperature, and humidity" .
:highDensityAltitudeCausesFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "The conditions that result in a high density altitude are high elevations, low atmospheric pressures, high temperatures, high humidity, or some combination of these factors" .
:lowDensityAltitudeCausesFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "Lower elevations, high atmospheric pressure, low temperatures, and low humidity are more indicative of low density altitude" .
