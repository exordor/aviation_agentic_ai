:chapter4 a :Cl_Chapter4PrinciplesOfFlight ;
    :hasChapter :chapter4SourcePage ;
    :asserts :introPrinciplesAssertion , :atmosphereDefinitionAssertion , :atmosphereCompositionAssertion , :heavierElementAssertion , :lighterElementAssertion , :oxygenAltitudeAssertion .

:chapter4SourcePage a :Cl_SourcePage , :Cl_PageProvenance ;
    :hasPageNumber "4-1" ;
    :derivedFrom :chapter4 ;
    :mentions :Cl_PrinciplesOfFlight , :Cl_Atmosphere , :Cl_Air , :Cl_Earth , :Cl_Nitrogen , :Cl_Oxygen , :Cl_OtherAtmosphericGases , :Cl_Argon , :Cl_Helium , :Cl_Airplane , :Cl_Helicopter , :Cl_Glider , :Cl_Balloon .

:introPrinciplesAssertion a :Cl_FlightPrincipleAssertion ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_AerodynamicForce , :Cl_FlightCondition , :Cl_FlightPerformanceCharacteristic , :Cl_Pilot , :Cl_ControlUnderstandingRequirement ;
    :governs :Cl_AerodynamicForce ;
    :affects :Cl_FlightPerformanceCharacteristic ;
    :hasOutcome :pilotUnderstandingSituation .

:pilotUnderstandingSituation a :Cl_AircraftControlSituation , :Cl_ControlUnderstandingRequirement ;
    :sourcePage :chapter4SourcePage ;
    :controls :Cl_Aircraft ;
    :requiresUnderstandingOf :Cl_PrinciplesOfFlight , :Cl_AerodynamicForce ;
    :usesOrCounteracts :Cl_AerodynamicForce ;
    :hasCondition :controlOfAircraftCondition ;
    :hasOutcome :aircraftControlOutcome .

:controlOfAircraftCondition a :Cl_FlightCondition ;
    :sourcePage :chapter4SourcePage ;
    :appliesTo :Cl_Aircraft .

:aircraftControlOutcome a :Cl_FlightPerformanceCharacteristic ;
    :sourcePage :chapter4SourcePage ;
    :affects :Cl_Aircraft .

:atmosphereDefinitionAssertion a :Cl_AtmosphericComposition ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_Atmosphere , :Cl_Air , :Cl_Earth , :Cl_EarthSurface ;
    :surrounds :Cl_Earth ;
    :restsUpon :Cl_EarthSurface ;
    :hasCondition :airAsGasMixtureCondition ;
    :hasOutcome :atmosphereMassWeightShapeOutcome .

:airAsGasMixtureCondition a :Cl_FlightCondition ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_Air , :Cl_Fluid .

:atmosphereMassWeightShapeOutcome a :Cl_Constraint ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "mass, weight, and indefinite shape" .

:atmosphereCompositionAssertion a :Cl_AtmosphericElementDistribution ;
    :sourcePage :chapter4SourcePage ;
    :hasConstituent :Cl_Nitrogen , :Cl_Oxygen , :Cl_OtherAtmosphericGases ;
    :hasFractionAssertion :nitrogenFractionAssertion , :oxygenFractionAssertion , :otherGasesFractionAssertion .

:nitrogenFractionAssertion a :Cl_QuantityAssertion ;
    :sourcePage :chapter4SourcePage ;
    :appliesTo :Cl_Nitrogen ;
    :hasFractionValue "78"^^xsd:decimal ;
    :hasPercentageValue "78"^^xsd:decimal ;
    :hasUnit "%" .

:oxygenFractionAssertion a :Cl_QuantityAssertion ;
    :sourcePage :chapter4SourcePage ;
    :appliesTo :Cl_Oxygen ;
    :hasFractionValue "21"^^xsd:decimal ;
    :hasPercentageValue "21"^^xsd:decimal ;
    :hasUnit "%" .

:otherGasesFractionAssertion a :Cl_QuantityAssertion ;
    :sourcePage :chapter4SourcePage ;
    :appliesTo :Cl_OtherAtmosphericGases ;
    :hasFractionValue "1"^^xsd:decimal ;
    :hasPercentageValue "1"^^xsd:decimal ;
    :hasUnit "%" ;
    :hasOutcome :otherGasExamples .

:otherGasExamples a :Cl_AtmosphericElement ;
    :sourcePage :chapter4SourcePage ;
    :hasMember :Cl_Argon , :Cl_Helium .

:heavierElementAssertion a :Cl_AtmosphericElementDistribution ;
    :sourcePage :chapter4SourcePage ;
    :hasCondition :heavierElementsCondition ;
    :hasOutcome :heavierElementsSettleOutcome .

:heavierElementsCondition a :Cl_HeavierAtmosphericElement ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_Oxygen ;
    :settlesTo :Cl_EarthSurface .

:heavierElementsSettleOutcome a :Cl_FlightCondition ;
    :sourcePage :chapter4SourcePage ;
    :locatedBelow :Cl_EarthSurface .

:lighterElementAssertion a :Cl_AtmosphericElementDistribution ;
    :sourcePage :chapter4SourcePage ;
    :hasCondition :lighterElementsCondition ;
    :hasOutcome :lighterElementsLiftOutcome .

:lighterElementsCondition a :Cl_LighterAtmosphericElement ;
    :sourcePage :chapter4SourcePage ;
    :liftedUpTo :higherAltitudeRegion .

:higherAltitudeRegion a :Cl_AltitudeRegion ;
    :sourcePage :chapter4SourcePage ;
    :locatedAbove :Cl_EarthSurface .

:lighterElementsLiftOutcome a :Cl_FlightCondition ;
    :sourcePage :chapter4SourcePage ;
    :locatedAbove :Cl_EarthSurface .

:oxygenAltitudeAssertion a :Cl_QuantityAssertion ;
    :sourcePage :chapter4SourcePage ;
    :appliesTo :Cl_Oxygen ;
    :belowAltitude :oxygenBelowAltitudeThreshold ;
    :hasNumericValue "35000"^^xsd:integer ;
    :hasUnit "feet" .

:oxygenBelowAltitudeThreshold a :Cl_Altitude , :Cl_QuantityAssertion ;
    :sourcePage :chapter4SourcePage ;
    :appliesTo :Cl_Oxygen ;
    :hasNumericValue "35000"^^xsd:integer ;
    :hasUnit "feet" .
:pilotRole a :Cl_PilotRole , owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :controls :Cl_Aircraft ;
    :requiresUnderstandingOf :Cl_PrinciplesOfFlight , :Cl_AerodynamicForce ;
    :usesOrCounteracts :Cl_AerodynamicForce .

:pilotPerson a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasRole :pilotRole ;
    :controls :Cl_Aircraft .

:aircraftTypesCollection a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasMember :Cl_Airplane , :Cl_Helicopter , :Cl_Glider , :Cl_Balloon .


