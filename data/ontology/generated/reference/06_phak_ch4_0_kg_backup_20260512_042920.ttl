    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_Airfoil , :Cl_Wing , :Cl_LeadingEdge , :Cl_TrailingEdge , :Cl_ChordLine , :Cl_UpperSurface , :Cl_LowerSurface , :Cl_Camber ;
    :hasTextValue "An airfoil is a structure designed to obtain reaction upon its surface from the air through which it moves or that moves past such a structure" .


:airfoilProducesLiftFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "the airfoils designed to produce lift" .

:wingAsAirfoilFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "the cross section of a wing" ;
    :hasPart :Cl_Wing .

