:airFluidClassificationAssertion a :Cl_FlightPrincipleAssertion ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_Air , :Cl_Fluid ;
    :asserts :airIsFluidFact .
:airIsFluidFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    rdf:type :Cl_Air , :Cl_Fluid .

:fluidShapeAssertion a :Cl_FlightPrincipleAssertion ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_Fluid , :Cl_Container ;
    :asserts :fluidTakesContainerShapeFact .
:fluidTakesContainerShapeFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasOutcome :containerShapeOutcome .
:containerShapeOutcome a :Cl_Container ;
    :sourcePage :chapter4SourcePage .

:fluidFlowCapabilityAssertion a :Cl_FlightPrincipleAssertion ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_Fluid , :Cl_FluidFlow ;
    :asserts :fluidCanFlowFact .
:fluidCanFlowFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasOutcome :flowCapabilityOutcome .
:flowCapabilityOutcome a :Cl_FluidFlow ;
    :sourcePage :chapter4SourcePage .

:airExpandsFillVolumeAssertion a :Cl_FlightPrincipleAssertion ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_Air , :Cl_Container ;
    :asserts :airExpandsToFillFact .
:airExpandsToFillFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasOutcome :availableVolumeOutcome .
:availableVolumeOutcome a :Cl_Container ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "available volume of its container" .

:viscosityDefinitionAssertion a :Cl_FluidPropertyAssertion ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_Viscosity , :Cl_Fluid ;
    :asserts :viscosityCausesFlowResistanceFact .
:viscosityCausesFlowResistanceFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :causes :flowResistanceState .
:flowResistanceState a :Cl_FlowResistance ;
    :sourcePage :chapter4SourcePage .

:adhesionDeterminesResistanceAssertion a :Cl_AdhesionAssertion ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_Adhesion , :Cl_Fluid , :Cl_Viscosity ;
    :asserts :molecularAdhesionDeterminesResistanceFact .
:molecularAdhesionDeterminesResistanceFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasCondition :adhesionCondition .
:adhesionCondition a :Cl_Adhesion ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "individual molecules tend to adhere, or stick, to each other" .

:airLowViscosityAssertion a :Cl_FluidPropertyAssertion ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_Air , :Cl_Viscosity ;
    :asserts :airLowViscosityFact .
:airLowViscosityFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "low viscosity" ;
    :hasOutcome :airFlowsEasilyFact .
:airFlowsEasilyFact a :Cl_AirFlow ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "flows easily" .

:fluidDensityDifferenceAssertion a :Cl_FlightPrincipleAssertion ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_Liquid , :Cl_Gas , :Cl_Density ;
    :asserts :liquidGasDensityDifferenceFact .
:liquidGasDensityDifferenceFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "differ greatly in density" .

:oilWaterRampAssertion a :Cl_FlightPrincipleAssertion ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_Fluid , :Cl_Viscosity ;
    :asserts :oilWaterDifferentRateFact .
:oilWaterDifferentRateFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "similar amounts of oil and water poured down two identical ramps will flow at different rates" .

:waterFlowsFreelyFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :rdf:type :Cl_Fluid ;
    :hasTextValue "water seems to flow freely" .
:oilFlowsSlowlyFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :rdf:type :Cl_Fluid ;
    :hasTextValue "oil flows much more slowly" .
:greaseViscousAssertion a :Cl_FluidPropertyAssertion ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_Fluid , :Cl_Viscosity ;
    :asserts :greaseVeryViscousFact .
:greaseVeryViscousFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "Grease is very viscous" .
:motorOilComparisonAssertion a :Cl_FluidPropertyAssertion ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_Fluid , :Cl_Viscosity ;
    :asserts :motorOilLessViscousThanGreaseFact , :motorOilMoreViscousThanGasolineFact .
:motorOilLessViscousThanGreaseFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "Motor oil is less viscous than grease" .
:motorOilMoreViscousThanGasolineFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "Motor oil is more viscous than gasoline" .

:allFluidsViscousAssertion a :Cl_FluidPropertyAssertion ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_Fluid , :Cl_Viscosity , :Cl_FlowResistance ;
    :asserts :allFluidsHaveFlowResistanceFact .
:allFluidsHaveFlowResistanceFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "All fluids are viscous and have a resistance to flow" .

:airResistanceAroundObjectAssertion a :Cl_FluidPropertyAssertion ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_Air , :Cl_Object , :Cl_FlowResistance ;
    :asserts :airResistsFlowAroundObjectFact .
:airResistsFlowAroundObjectFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "air resists flow around any object to some extent" .

:frictionDefinitionAssertion a :Cl_FrictionAssertion ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_Friction , :Cl_Surface , :Cl_Object ;
    :asserts :frictionIsResistanceFact .
:frictionIsResistanceFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "resistance that one surface or object encounters when moving over another" .
:frictionBetweenMaterialsAssertion a :Cl_FrictionAssertion ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_Friction , :Cl_Material , :Cl_Surface ;
    :asserts :frictionBetweenContactingMaterialsFact .
:frictionBetweenContactingMaterialsFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "Friction exists between any two materials that contact each other" .

:rampFlowDifferenceAssertion a :Cl_FlightPrincipleAssertion ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_FluidFlow , :Cl_Friction ;
    :asserts :roughRampImpedesFlowFact .
:roughRampImpedesFlowFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "rough surface ramp impedes the flow of the fluid" .
:identicalRampsSameFlowAssertion a :Cl_FlightPrincipleAssertion ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_FluidFlow ;
    :asserts :identicalFluidsSameSpeedFact .
:identicalFluidsSameSpeedFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "identical fluids flow in the same manner and at the same speed" .

:surfaceMicroscopicRoughnessAssertion a :Cl_RoughnessAssertion ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_Surface , :Cl_MicroscopicSurfaceRoughness ;
    :asserts :allSurfacesMicroscopicallyRoughFact .
:allSurfacesMicroscopicallyRoughFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "all surfaces, no matter how smooth they appear, are not smooth on a microscopic level" .

:wingSurfaceRoughnessAssertion a :Cl_RoughnessAssertion ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_Wing , :Cl_MicroscopicSurfaceRoughness ;
    :asserts :wingHasMicroscopicRoughnessFact .
:wingHasMicroscopicRoughnessFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "The surface of a wing has a certain roughness at the microscopic level" .
:wingRoughnessSlowsAirAssertion a :Cl_FrictionAssertion ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_Wing , :Cl_Air , :Cl_FlowResistance ;
    :asserts :wingRoughnessSlowsAirFact .
:wingRoughnessSlowsAirFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "surface roughness causes resistance and slows the velocity of the air flowing over the wing" .

:airMoleculesAdhereAssertion a :Cl_AdhesionAssertion ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_AirMolecule , :Cl_Wing , :Cl_Friction , :Cl_Adhesion ;
    :asserts :airMoleculesAdhereToWingFact .
:airMoleculesAdhereToWingFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "Molecules of air pass over the surface of the wing and actually adhere to the surface because of friction" .
:airMoleculesNearSurfaceAssertion a :Cl_FlightPrincipleAssertion ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_AirMolecule , :Cl_RelativeVelocityNearZero , :Cl_Wing ;
    :asserts :airMoleculesNearZeroVelocityFact .
:airMoleculesNearZeroVelocityFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "Air molecules near the surface of the wing resist motion and have a relative velocity near zero" .
:surfaceImpedesMotionAssertion a :Cl_FrictionAssertion ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_Wing , :Cl_MicroscopicSurfaceRoughness , :Cl_AirMolecule ;
    :asserts :surfaceRoughnessImpedesMotionFact .
:surfaceRoughnessImpedesMotionFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "The roughness of the surface impedes their motion" .
:boundaryLayerAssertion a :Cl_BoundaryLayerAssertion ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_BoundaryLayer , :Cl_AirMolecule , :Cl_Wing ;
    :asserts :boundaryLayerIsAdheringMoleculesFact .
:boundaryLayerIsAdheringMoleculesFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "The layer of molecules that adhere to the wing surface is referred to as the boundary layer" .

:airMoleculeLayer a :Cl_BoundaryLayer ;
    :sourcePage :chapter4SourcePage ;
    :formsLayerOf :Cl_Wing ;
    :hasPart :wingSurfaceMolecules .

