:nonstandardTemperatureAndPressureAssertion a :Cl_FlightPrincipleAssertion ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_NonstandardTemperatureAndPressure , :Cl_TemperatureLapseRate , :Cl_PressureLapseRate ;
    :asserts :nonstandardTemperatureAndPressureFact .
