    :mentions :Cl_Aircraft , :Cl_Engine , :Cl_HotGas ;
    :hasParticipant :Cl_Engine , :Cl_HotGas ;
    :hasOutcome :jetForwardMotionFact .

:jetForwardMotionFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "forces the airplane forward" .

:jetHotGasFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "the engine pushes a blast of hot gases backward" .


