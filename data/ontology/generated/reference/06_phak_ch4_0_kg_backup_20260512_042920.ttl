:pressureDefinitionAssertion a :Cl_PressureAssertion ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_Pressure , :Cl_Object , :Cl_Surface ;
    :hasTextValue "Pressure is the force applied in a perpendicular direction to the surface of an object." .
:psiDefinitionAssertion a :Cl_PressureAssertion ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_Pressure , :Cl_PSIUnit ;
    :hasTextValue "pressure is measured in pounds of force exerted per square inch of an object, or PSI" .
:fluidPressureUniformAssertion a :Cl_PressureAssertion ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_Object , :Cl_Fluid , :Cl_Pressure ;
    :hasTextValue "An object completely immersed in a fluid will feel pressure uniformly around the entire surface of the object." .
:lowerPressureMotionAssertion a :Cl_PressureAssertion ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_Pressure , :Cl_Object , :Cl_Motion ;
    :hasTextValue "If the pressure on one surface of the object becomes less than the pressure exerted on the other surfaces, the object will move in the direction of the lower pressure." .

:atmosphericPressureDefinitionAssertion a :Cl_FlightPrincipleAssertion ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_AtmosphericPressure , :Cl_Atmosphere , :Cl_Pilot , :Cl_FlightInstrument ;
    :hasTextValue "Pilots are mainly concerned with atmospheric pressure." .
:atmosphericPressureInstrumentAssertion a :Cl_FlightPrincipleAssertion ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_Altimeter , :Cl_AirspeedIndicator , :Cl_VerticalSpeedIndicator , :Cl_ManifoldPressureGauge , :Cl_AtmosphericPressure ;
    :hasTextValue "Atmospheric pressure actuates the altimeter, airspeed indicator, vertical speed indicator, and manifold pressure gauge." .

:airMassGravityAssertion a :Cl_FlightPrincipleAssertion ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_Air , :Cl_Mass , :Cl_Gravity , :Cl_Pressure ;
    :hasTextValue "Air has mass and is affected by the attraction of gravity; because of its weight, it has force, and its effect on bodies within the air is called pressure." .
:atmosphericPressureAltitudeAssertion a :Cl_FlightPrincipleAssertion ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_AtmosphericPressure , :Cl_Altitude , :Cl_Atmosphere ;
    :hasTextValue "the higher the altitude, the less air there is above" .
:atmosphereHalfWeightAssertion a :Cl_QuantityAssertion ;
    :sourcePage :chapter4SourcePage ;
    :appliesTo :Cl_Atmosphere ;
    :hasNumericValue "18000"^^xsd:integer ;
    :hasUnit :Cl_FootUnit ;
    :hasTextValue "the weight of the atmosphere at 18,000 feet is one-half what it is at sea level" .

