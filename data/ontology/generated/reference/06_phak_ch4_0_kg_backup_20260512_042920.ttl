    :sourcePage :chapter4SourcePage ;
    :hasOutcome :performanceIncreasesWithLowerDensityAltitude , :performanceDecreasesWithHigherDensityAltitude .
:performanceIncreasesWithLowerDensityAltitude a :Cl_FlightPerformanceCharacteristic ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "aircraft performance increases as the density of the air increases (lower density altitude)" .
:performanceDecreasesWithHigherDensityAltitude a :Cl_FlightPerformanceCharacteristic ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "aircraft performance decreases as air density decreases (higher density altitude)" .
:airDensityEffectAssertion a :Cl_FlightPrincipleAssertion ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_AirDensity , :Cl_Power , :Cl_Thrust , :Cl_Lift ;
    :asserts :airDensityReductionFact .
:airDensityReductionFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :reduces :Cl_Power , :Cl_Thrust , :Cl_Lift ;
    :hasTextValue "as air becomes less dense, it reduces power, thrust, and lift" .
:enginePowerReductionFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :causes :Cl_Power ;
    :hasTextValue "the engine takes in less air" .
:propellerThrustReductionFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :causes :Cl_Thrust ;
    :hasTextValue "a propeller is less efficient in thin air" .
:liftReductionFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :causes :Cl_Lift ;
    :hasTextValue "the thin air exerts less force on the airfoils" .
