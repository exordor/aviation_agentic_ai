:pressureLapseRateFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "pressure decreases at a rate of approximately 1 \"Hg per 1,000 feet of altitude gain to 10,000 feet" .

