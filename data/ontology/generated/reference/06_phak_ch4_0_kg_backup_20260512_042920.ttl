    :mentions :Cl_UpperSurface , :Cl_LowerSurface , :Cl_Camber ;
    :asserts :upperSurfaceCamberMorePronouncedFact .

:upperSurfaceCamberMorePronouncedFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "the camber of the upper surface is more pronounced than that of the lower surface" .

:lowerSurfaceFlatFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_LowerSurface ;
    :hasTextValue "which is usually somewhat flat" .

:airfoilLeadingEdgeFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_LeadingEdge ;
    :hasTextValue "the rounded end, which faces forward in flight, is called the leading edge" .

:airfoilTrailingEdgeFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_TrailingEdge ;
    :hasTextValue "the other end, the trailing edge, is quite narrow and tapered" .

:airfoilChordLineAssertion a :Cl_AirfoilGeometryAssertion ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_ChordLine , :Cl_LeadingEdge , :Cl_TrailingEdge ;
    :hasTextValue "a straight line drawn through the profile connecting the extremities of the leading and trailing edges" .

:camberMeasurementFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_ChordLine , :Cl_Camber , :Cl_UpperSurface , :Cl_LowerSurface ;
    :hasTextValue "The distance from this chord line to the upper and lower surfaces of the wing denotes the magnitude of the upper and lower camber at any point" .

:wingTopVelocityAssertion a :Cl_CausalRelationAssertion ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_Wing , :Cl_AirFlow , :Cl_UpperSurface ;
    :hasOutcome :wingTopVelocityIncreaseFact .

:wingTopVelocityIncreaseFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "the flow of air across the curved top surface increases in velocity" .

:wingLowPressureAssertion a :Cl_CausalRelationAssertion ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_Wing , :Cl_LowPressureArea , :Cl_AirFlow ;
    :hasOutcome :wingLowPressureAreaFact .

:wingLowPressureAreaFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "creating a low-pressure area" .


:wingLiftGenerationAssertion a :Cl_BernoulliCausalAssertion ;
    :sourcePage :chapter4SourcePage ;
    :mentions :Cl_Wing , :Cl_Lift , :Cl_BernoulliPrinciple , :Cl_LowPressureArea ;
    :hasCondition :wingTopVelocityIncreaseFact ;
    :hasOutcome :wingDevelopsLiftFact .

:wingDevelopsLiftFact a owl:NamedIndividual ;
    :sourcePage :chapter4SourcePage ;
    :hasTextValue "the wing develops lift as the wing moves through the air" .
