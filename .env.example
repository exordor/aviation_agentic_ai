# LLM provider configuration for future ontology generation and extraction.
# Milestone 1 validation/reporting commands do not require these values.
LLM_PROVIDER=openai
MODEL_NAME=gpt-5.4-mini
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
# For an OpenAI-compatible relay, set OPENAI_BASE_URL in your local ignored .env.
# Example: OPENAI_BASE_URL=https://api.tu-zi.com/v1
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
VLLM_PORT=8000
